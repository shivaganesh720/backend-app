<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h2>Orders Admin Page</h2>
    <a href="/orders/add">Add Order</a>
    <ol>
        <% orders.forEach(order=> { %>
            <li>
                <%= order.products %>-
                    <%= order.status %>-
                        <%= order.createdAt %>-
                            <%= order.updatedAt %>-
                                <a href="/orders/<%= order._id %>/edit">Edit</a>-
                                <a href="/orders/<%= order._id %>/delete">Delete</a>
            </li>
            <% }) %>
    </ol>
</body>

</html>