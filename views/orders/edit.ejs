<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h2>Orders Edit Form</h2>
    <form action="/orders/<%= order._id %>/save" method="POST">
        <p><input type="text" name="name" value="<%= order.name %>"></p>
        <p><input type="text" name="email" value="<%= order.email %>"></p>
        <p><input type="text" name="role" value="<%= order.role %>"></p>
        <p><button>Save</button></p>
    </form>
</body>

</html>